---
import BaseLayout from '../layouts/BaseLayout.astro';
import HeroWithLeadForm from '../components/HeroWithLeadForm.astro';
import { BRAND } from '../data/brand';
import { SERVICES } from '../data/services';
import { LOCATIONS } from '../data/locations';
import { getCompleteHomepageSchema, getFAQSchema } from '../utils/schema';
import { HOMEPAGE_FAQS } from '../data/faqs';

const title = `Blocked Drains Bath | 24/7 Emergency Unblocking`;
const description = `Blocked drains in Bath fixed fast. Local engineers, fixed pricing, and 24/7 emergency drainage response. Call ${BRAND.phoneFormatted} or request a quote online.`;
---

<BaseLayout title={title} description={description} canonical="/" schema={[...getCompleteHomepageSchema(), getFAQSchema(HOMEPAGE_FAQS.slice(0, 6))]}>
  <HeroWithLeadForm
    title="Blocked Drains Bath — Fast, Local Drainage Experts"
    description="Plumbing done right in Bath. We diagnose the issue, quote a fair price, and complete the work to a high standard — backed by our 12-month guarantee."
    formId="home-lead-form"
    source="homepage"
  />

  <section class="section-padding">
    <div class="container-wide px-4">
      <h2 class="text-2xl md:text-3xl font-bold mb-8">Popular drainage services</h2>
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
        {SERVICES.map((service) => (
          <article class="bg-card p-6 rounded-xl card-elevated">
            <span class="text-3xl mb-2 block" aria-hidden="true">{service.icon}</span>
            <h3 class="text-xl font-bold mb-2">{service.name}</h3>
            <p class="text-muted-foreground text-sm">{service.shortLabel}</p>
            <a href={`/services/${service.slug}/`} class="btn-outline mt-4 no-underline">{service.name} details</a>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section-padding bg-white">
    <div class="container-wide px-4">
      <h2 class="text-2xl md:text-3xl font-bold mb-8">How it works</h2>
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
        <article class="bg-card p-6 rounded-xl border border-border shadow-sm"><h3 class="text-xl font-bold mb-2">1) Describe your drainage issue</h3><p class="text-muted-foreground">Tell us what is happening and give us your Bath postcode so we can dispatch the nearest available engineer to your property.</p></article>
        <article class="bg-card p-6 rounded-xl border border-border shadow-sm"><h3 class="text-xl font-bold mb-2">2) A local Bath engineer arrives promptly</h3><p class="text-muted-foreground">One of our qualified drainage specialists arrives with professional jetting and CCTV equipment, ready to diagnose the problem on the spot.</p></article>
        <article class="bg-card p-6 rounded-xl border border-border shadow-sm"><h3 class="text-xl font-bold mb-2">3) Problem solved with aftercare guidance</h3><p class="text-muted-foreground">We clear or repair the issue, walk you through what caused it, and share tailored advice to help you avoid repeat blockages in the future.</p></article>
      </div>
    </div>
  </section>

  <section class="section-padding">
    <div class="container-wide px-4">
      <h2 class="text-2xl md:text-3xl font-bold mb-8">Why choose us</h2>
      <ul class="grid md:grid-cols-2 gap-6 list-none p-0">
        <li class="bg-card p-6 rounded-xl border border-border shadow-sm">Transparent pricing with no hidden fees — you get a clear quote before any work begins.</li>
        <li class="bg-card p-6 rounded-xl border border-border shadow-sm">Fully qualified engineers serving Bath, Bathwick, Widcombe, Larkhall, and all of Somerset.</li>
        <li class="bg-card p-6 rounded-xl border border-border shadow-sm">Latest diagnostic technology including HD CCTV cameras for accurate fault-finding.</li>
        <li class="bg-card p-6 rounded-xl border border-border shadow-sm">Round-the-clock emergency availability — we are here whenever you need us, day or night.</li>
      </ul>
    </div>
  </section>

  <section class="section-padding bg-white">
    <div class="container-wide px-4">
      <h2 class="text-2xl md:text-3xl font-bold mb-4">Coverage near Bath</h2>
      <p class="text-muted-foreground mb-8">We cover Somerset and Wiltshire locations including:</p>
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
        {LOCATIONS.map((location) => (
          <a class="bg-card p-6 rounded-xl border border-border shadow-sm hover:shadow-md hover:border-primary transition-all no-underline text-foreground" href={`/locations/${location.slug}/`}>Blocked drains in {location.name}</a>
        ))}
      </div>
    </div>
  </section>

  <section class="section-padding">
    <div class="container-wide px-4">
      <h2 class="text-2xl md:text-3xl font-bold mb-8">Frequently asked questions</h2>
      <div class="max-w-3xl mx-auto space-y-4">
        {HOMEPAGE_FAQS.slice(0, 6).map((faq, i) => (
          <details class="bg-card rounded-lg card-elevated group" open={i === 0}>
            <summary class="p-4 md:p-6 cursor-pointer font-semibold text-lg hover:text-primary transition-colors flex items-center justify-between">
              {faq.question}
              <svg aria-hidden="true" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="shrink-0 ml-2 group-open:rotate-180 transition-transform"><path d="m6 9 6 6 6-6"></path></svg>
            </summary>
            <div class="px-4 md:px-6 pb-4 md:pb-6 text-muted-foreground"><p>{faq.answer}</p></div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <section class="section-padding bg-slate-900 text-white">
    <div class="container-wide px-4 text-center">
      <h2 class="text-3xl md:text-4xl font-bold mb-4">Need urgent drainage help?</h2>
      <p class="text-lg text-white/80 mb-8">Call now for a rapid response anywhere in {BRAND.serviceAreaLabel}.</p>
      <a class="bg-white text-primary font-semibold px-8 py-4 rounded-lg shadow-lg hover:bg-white/90 transition-all text-lg inline-block no-underline" href={`tel:${BRAND.phone}`}>Call {BRAND.phoneFormatted}</a>
    </div>
  </section>
</BaseLayout>
